<div class="hs-alert hs-alert--@GetVariantClass()">
    <i class="@GetIcon() hs-alert__icon"></i>
    <span>@Message</span>
</div>

@code {
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public AlertVariant Variant { get; set; } = AlertVariant.Info;

    private string GetVariantClass() => Variant switch
    {
        AlertVariant.Info => "info",
        AlertVariant.Success => "success",
        AlertVariant.Warning => "warning",
        AlertVariant.Danger => "danger",
        AlertVariant.Error => "error",
        _ => "info"
    };

    private string GetIcon() => Variant switch
    {
        AlertVariant.Info => "bx bx-info-circle",
        AlertVariant.Success => "bx bx-check-circle",
        AlertVariant.Warning => "bx bx-error",
        AlertVariant.Danger => "bx bx-x-circle",
        AlertVariant.Error => "bx bx-error-circle",
        _ => "bx bx-info-circle"
    };

    public enum AlertVariant
    {
        Info,
        Success,
        Warning,
        Danger,
        Error
    }
}

<style>
    .hs-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 12px;
        border: 1px solid transparent;
    }

    .hs-alert__icon {
        font-size: 18px;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .hs-alert--info {
        background: #E3F2FD;
        color: #1565C0;
        border-color: #90CAF9;
    }

    .hs-alert--success {
        background: #E8F5E9;
        color: #2E7D32;
        border-color: #A5D6A7;
    }

    .hs-alert--warning {
        background: #FFF8E1;
        color: #F57F17;
        border-color: #FFE082;
    }

    .hs-alert--danger {
        background: #FFEBEE;
        color: #C62828;
        border-color: #EF9A9A;
    }

    .hs-alert--error {
        background: #fdecea;
        color: #c0392b;
        border-color: #f5c6c2;
    }
</style>