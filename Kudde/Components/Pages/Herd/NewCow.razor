@using Kudde.Shared.DTO.Animal

<HsDialog Visible="true" Title="@(ExistingCow != Guid.Empty ? "Edit Animal" : "Add New Animal")">
    <Content>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
                <label>Animal Type Code</label>
                <select @bind="species.AnimalTypeCode" class="form-control" required>
                    @foreach (var type in animalTypes)
                    {
                        <option value="@type.AnimalTypeCode">@type.AnimalTypeName</option>
                    }
                </select>
                <label class="mt-2">Display Identifier</label>
                <div class="input-group">
                    <span class="input-group-text">#</span>
                    <input type="text" @bind="species.DisplayIdentifier" class="form-control" placeholder="Display Identifier" required />
                </div>
                <label class="mt-2">Birth Year</label>
                <input type="text" @bind="species.BirthYear" class="form-control" placeholder="Birth Year" />
                <label class="mt-2">Weight</label>
                <div class="input-group">
                    <input type="text" @bind="species.Weight" class="form-control" placeholder="Weight" />
                    <span class="input-group-text">kg</span>
                </div>
                <div class="mt-2">
                    <label><input type="radio" name="gender" value="M" @onchange='() => species.Gender = "M"' /> Male</label>
                    <label class="ms-2"><input type="radio" name="gender" value="F" @onchange='() => species.Gender = "F"' /> Female</label>
                    <label class="ms-2"><input type="radio" name="gender" value="U" @onchange='() => species.Gender = "U"' /> Unknown</label>
                </div>
                <div class="mt-2">
                    <HsAutocomplete TItem="AnimalDTO"
                                    @bind-Value="SelectedMother"
                                    SearchFunc="Search"
                                    ToStringFunc="@(a => a?.DisplayIdentifier ?? string.Empty)"
                                    MinCharacters="0"
                                    Placeholder="Please select mother" />
                </div>
            </div>
            <div>
                <label>Father</label>
                <HsAutocomplete TItem="AnimalDTO"
                                @bind-Value="SelectedFather"
                                SearchFunc="Search"
                                ToStringFunc="@(a => a?.DisplayIdentifier ?? string.Empty)"
                                MinCharacters="0"
                                Placeholder="Please select father" />
                <div class="form-check mt-2">
                    <input type="checkbox" class="form-check-input" @bind="species.IsBranded" id="brandedCheck" />
                    <label class="form-check-label" for="brandedCheck">Branded</label>
                </div>
                <label class="mt-2">Medical Note</label>
                <input type="text" @bind="species.MedicalNote" class="form-control" placeholder="Medical Note" />
                <label class="mt-2">Total Pregnancies</label>
                <input type="number" @bind="species.TotalPregnancies" class="form-control" min="0" />
                <label class="mt-2">Total Offspring</label>
                <input type="number" @bind="species.TotalCalves" class="form-control" min="0" />
                <label class="mt-2">Last Pregnancy</label>
                <input type="date" @bind="species.LastPregnancyDate" class="form-control" />
            </div>
        </div>
    </Content>
    <Buttons>
        <HsButton Text="Cancel" Variant="HsButton.ButtonVariant.Secondary" OnClick="Cancel" />
        <HsButton Text="OK" Variant="HsButton.ButtonVariant.Teal" OnClick="Submit" />
    </Buttons>
</HsDialog>