@page "/programs"
@attribute [Authorize]
@using BLL.Services
@using Kudde.Shared.DTO.Program
@rendermode @(new InteractiveServerRenderMode(prerender: true))
<PageTitle>Programs</PageTitle>
<PageHeader Title="Programs"
            Subtitle="Treatment programs set up for your farm."
            SubtitleInline="false"
            ButtonText="New Program"
            ButtonIcon="bx bx-plus"
            Href="/newprogram" />
<div class="container mt-3">
    @if (_loading)
    {
        <HerdLoader />
    }
    else if (_programs.Count == 0)
    {
        <HsAlert Message="No programs found. Create your first program to get started."
                 Variant="HsAlert.AlertVariant.Info" />
    }
    else
    {
        <div class="row">
            @foreach (var program in _programs)
            {
                <div class="col-lg-4 col-md-6 col-12 mt-4">
                    <div class="card border-0 rounded shadow h-100">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="mb-0">@program.TemplateName</h5>
                                @if (program.IsActive)
                                {
                                    <span class="badge rounded-pill bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary">Inactive</span>
                                }
                            </div>

                            <div class="mb-3">
                                @if (!string.IsNullOrEmpty(program.Frequency))
                                {
                                    <span class="badge me-1" style="background-color:#e8f0ea; color:#4a7c59; font-weight:500;">
                                        <i class="bx bx-refresh me-1"></i>@GetFrequencyLabel(program.Frequency)
                                    </span>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(program.Description))
                            {
                                <p class="text-muted small mb-3">@program.Description</p>
                            }

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center text-muted small mb-3">
                                    <span><i class="bx bx-code me-1"></i>@program.ProgramTemplateCode</span>
                                    @if (program.CreatedDate != default)
                                    {
                                        <span>@program.CreatedDate.ToString("dd MMM yyyy")</span>
                                    }
                                </div>
                                <div class="d-flex gap-2">
                                    <HsButton Text="View"
                                              Variant="HsButton.ButtonVariant.Outline"
                                              Icon="bx bx-show"
                                              OnClick="@(() => NavigationManager.NavigateTo($"/programs/{program.ProgramTemplateCode}"))"
                                              Class="w-100" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string GetFrequencyLabel(string? frequency) => frequency switch
    {
        "OnceOff" => "Once-off",
        "Monthly" => "Monthly",
        "Quarterly" => "Quarterly",
        "BiYearly" => "Bi-yearly",
        "Yearly" => "Yearly",
        _ => frequency ?? "Unknown"
    };
}