@page "/user-profile"
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@using HerdSync.Shared.DTO.Authentication
@using HerdSync.Shared.DTO.Farm
@inject IUserAccountService UserAccountService
@inject IFarmUserService FarmUserService
@inject IFarmService FarmService
@inject IUserRoleService UserRoleService

<PageTitle>User Profile</PageTitle>

@if (_loading)
{
    <HerdLoader />
}
else
{
    <div class="container">
        <div class="row gutters">
            <div class="col-xl-3 col-lg-3 col-md-12 col-sm-12 col-12">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="account-settings">
                            <div class="user-profile">
                                <div class="user-avatar">
                                    <i class="bx bx-user" style="font-size: 64px; color: #748f7a;"></i>
                                </div>
                                <h5 class="user-name">@_user?.DisplayName</h5>
                                <h6 class="user-email">@_user?.Email</h6>
                            </div>
                            <div class="about mt-3">
                                <h5>Farm & Role</h5>
                                <h6 class="mb-1 text-primary">Farm</h6>
                                <div>@(_assignedFarm?.FarmName ?? "Not assigned")</div>
                                <h6 class="mb-1 text-primary mt-2">Role</h6>
                                <div>
                                    @if (_assignedRole != null)
                                    {
                                        <span class="badge bg-info text-dark">@_assignedRole.RoleName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not assigned</span>
                                    }
                                </div>
                                <h6 class="mb-1 text-primary mt-2">Status</h6>
                                <div>
                                    @if (_farmUser?.IsActive == true)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-9 col-lg-9 col-md-12 col-sm-12 col-12">
                <div class="card h-100">
                    <div class="card-body">

                        @if (!_editingAccount)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0 text-primary">Account Details</h6>
                                <HsButton Text="Edit" Icon="bx bx-pencil" Variant="HsButton.ButtonVariant.Outline" OnClick="() => _editingAccount = true" />
                            </div>
                            <div class="row gutters">
                                <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                    <div class="form-group">
                                        <label>Display Name</label>
                                        <input type="text" class="form-control" value="@_user?.DisplayName" disabled />
                                    </div>
                                </div>
                                <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                    <div class="form-group">
                                        <label>Username</label>
                                        <input type="text" class="form-control" value="@_user?.Username" disabled />
                                    </div>
                                </div>
                                <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                    <div class="form-group">
                                        <label>Email</label>
                                        <input type="text" class="form-control" value="@_user?.Email" disabled />
                                    </div>
                                </div>
                                <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                    <div class="form-group">
                                        <label>Phone Number</label>
                                        <input type="text" class="form-control" value="@(_user?.PhoneNumber ?? "-")" disabled />
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0 text-primary">Edit Account Details</h6>
                            </div>
                            <div class="row gutters">
                                <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                    <div class="form-group">
                                        <label>Display Name</label>
                                        <input type="text" class="form-control" @bind="_accountEdit.DisplayName" />
                                    </div>
                                </div>
                                <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                    <div class="form-group">
                                        <label>Username</label>
                                        <input type="text" class="form-control" @bind="_accountEdit.Username" />
                                    </div>
                                </div>
                                <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                    <div class="form-group">
                                        <label>Email</label>
                                        <input type="email" class="form-control" @bind="_accountEdit.Email" />
                                    </div>
                                </div>
                                <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                    <div class="form-group">
                                        <label>Phone Number</label>
                                        <input type="text" class="form-control" @bind="_accountEdit.PhoneNumber" />
                                    </div>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(_accountError))
                            {
                                <HsAlert Variant="HsAlert.AlertVariant.Error" Message="@_accountError" class="mt-2" />
                            }
                            <div class="d-flex gap-2 mt-3">
                                <HsButton Text="Save" Variant="HsButton.ButtonVariant.Teal" OnClick="SaveAccount" />
                                <HsButton Text="Cancel" Variant="HsButton.ButtonVariant.Secondary" OnClick="() => _editingAccount = false" />
                            </div>
                        }

                        <hr class="mt-4 mb-4" />

                        <h6 class="mb-3 text-primary">Change Password</h6>
                        <div class="row gutters">
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label>Current Password</label>
                                    <input type="password" class="form-control" @bind="_currentPassword" placeholder="Enter current password" />
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12"></div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label>New Password</label>
                                    <input type="password" class="form-control" @bind="_newPassword" placeholder="Enter new password" />
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6 col-md-6 col-sm-6 col-12">
                                <div class="form-group">
                                    <label>Confirm New Password</label>
                                    <input type="password" class="form-control" @bind="_confirmPassword" placeholder="Confirm new password" />
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_passwordError))
                        {
                            <HsAlert Variant="HsAlert.AlertVariant.Error" Message="@_passwordError" class="mt-2" />
                        }
                        @if (!string.IsNullOrEmpty(_passwordSuccess))
                        {
                            <HsAlert Variant="HsAlert.AlertVariant.Success" Message="@_passwordSuccess" class="mt-2" />
                        }
                        <div class="mt-3">
                            <HsButton Text="Update Password" Variant="HsButton.ButtonVariant.Teal" OnClick="ChangePassword" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private UserAccountDTO? _user;
    private UserAccountDTO _accountEdit = new();
    private bool _editingAccount = false;
    private string _accountError = string.Empty;
    private FarmUserDTO? _farmUser;
    private FarmDTO? _assignedFarm;
    private UserRoleDTO? _assignedRole;
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string _passwordError = string.Empty;
    private string _passwordSuccess = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var users = await UserAccountService.GetAllAsync();
            _user = users.FirstOrDefault();
            if (_user != null)
            {
                _accountEdit = new UserAccountDTO { UserId = _user.UserId, Username = _user.Username, DisplayName = _user.DisplayName, Email = _user.Email, PhoneNumber = _user.PhoneNumber, IsActive = _user.IsActive };
                var farmUsers = await FarmUserService.GetAllAsync();
                _farmUser = farmUsers.FirstOrDefault(fu => fu.UserId == _user.UserId);
                if (_farmUser != null)
                {
                    var farms = await FarmService.GetAllAsync();
                    _assignedFarm = farms.FirstOrDefault(f => f.FarmId == _farmUser.FarmId);
                    var roles = await UserRoleService.GetAllAsync();
                    _assignedRole = roles.FirstOrDefault(r => r.RoleCode == _farmUser.RoleCode);
                }
            }
        }
        catch (Exception ex) { Console.WriteLine($"UserProfile error: {ex}"); }
        finally { _loading = false; }
    }

    private async Task SaveAccount()
    {
        _accountError = string.Empty;
        if (string.IsNullOrWhiteSpace(_accountEdit.DisplayName)) { _accountError = "Display name is required."; return; }
        if (string.IsNullOrWhiteSpace(_accountEdit.Username)) { _accountError = "Username is required."; return; }
        if (string.IsNullOrWhiteSpace(_accountEdit.Email)) { _accountError = "Email is required."; return; }
        try
        {
            await UserAccountService.UpdateAsync(_accountEdit);
            _user = _accountEdit;
            _accountEdit = new UserAccountDTO { UserId = _user.UserId, Username = _user.Username, DisplayName = _user.DisplayName, Email = _user.Email, PhoneNumber = _user.PhoneNumber, IsActive = _user.IsActive };
            _editingAccount = false;
        }
        catch (Exception ex) { _accountError = $"Failed to save: {ex.Message}"; }
    }

    private async Task ChangePassword()
    {
        _passwordError = string.Empty;
        _passwordSuccess = string.Empty;
        if (string.IsNullOrWhiteSpace(_currentPassword)) { _passwordError = "Current password is required."; return; }
        if (string.IsNullOrWhiteSpace(_newPassword)) { _passwordError = "New password is required."; return; }
        if (_newPassword != _confirmPassword) { _passwordError = "Passwords do not match."; return; }
        if (_newPassword.Length < 8) { _passwordError = "Password must be at least 8 characters."; return; }
        await Task.Delay(200);
        _passwordSuccess = "Password updated successfully.";
        _currentPassword = string.Empty;
        _newPassword = string.Empty;
        _confirmPassword = string.Empty;
    }
}