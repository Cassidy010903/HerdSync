@page "/programhistory"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@inject ITreatmentService TreatmentService
@inject IProgramTemplateRuleService ProgramTemplateRuleService
@inject IProgramTemplateRuleTreatmentService ProgramTemplateRuleTreatmentService
@using HerdSync.Shared.DTO.Program

<div class="container">
    <div class="text-center mb-4">
        <h3>Program History</h3>
        <p class="lead">Previously run programs and their data</p>
    </div>

    @if (!_loading)
    {
        <div class="row align-items-center mb-3">
            <div class="col-md-6">
                <input class="hs-input"
                       value="@_searchTerm"
                       @oninput="@((e) => OnSearchChanged(e.Value?.ToString() ?? string.Empty))"
                       placeholder="Search by program name..." />
            </div>
            <div class="col-md-6 d-flex justify-content-end">
                <div class="hs-filter-dropdown">
                    <button class="hs-btn hs-btn--outline" @onclick="ToggleFilterPanel">
                        <i class="bx bx-filter-alt me-1"></i> Filter
                        @if (HasActiveFilters)
                        {
                            <span class="hs-filter-badge"></span>
                        }
                    </button>
                    @if (_filterPanelOpen)
                    {
                        <div class="hs-filter-dropdown__backdrop" @onclick="() => _filterPanelOpen = false"></div>
                        <div class="hs-filter-dropdown__panel" style="width: 260px;">
                            <p class="hs-filter-dropdown__panel-title">Filter Runs</p>

                            <label class="hs-filter-dropdown__label">Program</label>
                            <select class="form-select form-select-sm mb-2"
                                    @bind="_programFilter">
                                <option value="">All Programs</option>
                                @foreach (var p in _availablePrograms)
                                {
                                    <option value="@p.Key">@p.Value</option>
                                }
                            </select>

                            <label class="hs-filter-dropdown__label">Date From</label>
                            <input type="date" class="form-control form-control-sm mb-2"
                                   @bind="_dateFrom" />

                            <label class="hs-filter-dropdown__label">Date To</label>
                            <input type="date" class="form-control form-control-sm mb-2"
                                   @bind="_dateTo" />

                            <button class="hs-filter-dropdown__clear" @onclick="ClearFilters">
                                Clear all filters
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (_loading)
    {
        <HerdLoader />
    }
    else if (!GroupedRuns.Any())
    {
        <div class="text-center text-muted mt-5">
            <i class="bx bx-history" style="font-size: 48px;"></i>
            <p class="mt-2">No program history found.</p>
        </div>
    }
    else
    {
        @foreach (var group in GroupedRuns)
        {
            <div class="mb-2 mt-4">
                <span class="text-muted small fw-semibold text-uppercase">
                    <i class="bx bx-calendar me-1"></i>@group.Key.ToString("dd MMMM yyyy")
                </span>
                <hr class="mt-1 mb-2" />
            </div>
            @foreach (var program in group)
            {
                <div class="card mb-2">
                    <div class="card-body py-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-3">
                                <span class="avatar avatar-text rounded-3 px-2" style="width: auto; min-width: 40px; font-size: 11px; background: #4a7c59;">
                                    @program.ProgramTemplateCode
                                </span>
                                <div>
                                    <h6 class="mb-0">@GetTemplateName(program.ProgramTemplateCode)</h6>
                                    @if (!string.IsNullOrEmpty(program.Notes))
                                    {
                                        <small class="text-muted">@program.Notes</small>
                                    }
                                </div>
                            </div>
                            <HsButton Text="View"
                                      Icon="bx bx-show"
                                      Variant="HsButton.ButtonVariant.Outline"
                                      OnClick="@(() => ViewRun(program.ProgramRunId))" />
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

<style>
    body {
        background: #f2f0f0;
    }

    .card {
        box-shadow: 0 20px 27px 0 rgb(0 0 0 / 5%);
        position: relative;
        display: flex;
        flex-direction: column;
        min-width: 0;
        word-wrap: break-word;
        background-color: #fff;
        background-clip: border-box;
        border: 0 solid rgba(0,0,0,.125);
        border-radius: 1rem;
    }

    .card-body {
        flex: 1 1 auto;
        padding: 1.5rem 1.5rem;
    }

    .avatar-text {
        display: flex;
        justify-content: center;
        align-items: center;
        background: #000;
        color: #fff;
        font-weight: 700;
    }

    .avatar {
        width: 3rem;
        height: 3rem;
    }

    .rounded-3 {
        border-radius: 0.5rem !important;
    }

    .bg-success {
        background-color: #748f7a !important;
    }

    .btn-primary {
        background-color: #90b499 !important;
        border-color: grey;
    }
</style>