@page "/programhistory"
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@using HerdSync.Shared.DTO.Program

<div class="container">
    <div class="text-center mb-5">
        <h3>Program History</h3>
        <p class="lead">Previously run programs and their data</p>
    </div>

    @if (_loading)
    {
        <HerdLoader />
    }
    else if (!GroupedRuns.Any())
    {
        <div class="text-center text-muted mt-5">
            <i class="bx bx-history" style="font-size: 48px;"></i>
            <p class="mt-2">No program history found.</p>
        </div>
    }
    else
    {
        @foreach (var group in GroupedRuns)
        {
            <div class="mb-2 mt-4">
                <span class="text-muted small fw-semibold text-uppercase">
                    <i class="bx bx-calendar me-1"></i>@group.Key.ToString("dd MMMM yyyy")
                </span>
                <hr class="mt-1 mb-2" />
            </div>

            @foreach (var program in group)
            {
                <div class="card mb-2">
                    <div class="card-body py-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-3">
                                <span class="avatar avatar-text rounded-3 px-2" style="width: auto; min-width: 40px; font-size: 11px;">@program.ProgramTemplateCode</span>
                                <div>
                                    <h6 class="mb-0">@GetTemplateName(program.ProgramTemplateCode)</h6>
                                    @if (!string.IsNullOrEmpty(program.Notes))
                                    {
                                        <small class="text-muted">@program.Notes</small>
                                    }
                                </div>
                            </div>
                            <button class="btn btn-outline-primary btn-sm" @onclick="() => ViewRun(program.ProgramRunId)">
                                <i class="bx bx-show"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>