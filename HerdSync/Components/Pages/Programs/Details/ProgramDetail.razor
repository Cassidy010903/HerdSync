@page "/programs/{ProgramTemplateCode}"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@using HerdSync.Shared.DTO.Program
@using HerdSync.Shared.DTO.Treatment
@using HerdSync.Shared.DTO.Animal
@inject IProgramTemplateService ProgramTemplateService
@inject IProgramTemplateRuleService ProgramTemplateRuleService
@inject IProgramTemplateRuleTreatmentService ProgramTemplateRuleTreatmentService
@inject ITreatmentService TreatmentService
@inject IAnimalTypeService AnimalTypeService
@inject NavigationManager Nav

@if (_loading)
{
    <HerdLoader />
}
else if (_template == null)
{
    <div class="text-center text-muted mt-5">
        <i class="bx bx-error" style="font-size: 48px;"></i>
        <p class="mt-2">Program not found.</p>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/programs")'>
            <i class="bx bx-arrow-back me-1"></i>Back
        </button>
        <div>
            <h4 class="mb-0">@_template.TemplateName</h4>
            <small class="text-muted">
                <span class="badge bg-secondary me-1">@_template.ProgramTemplateCode</span>
                @if (_template.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactive</span>
                }
            </small>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header py-3">
                    <h6 class="mb-0"><i class="bx bx-list-check me-1"></i>Rules</h6>
                </div>
                <div class="card-body">
                    @if (!_rules.Any())
                    {
                        <p class="text-muted small">No rules configured for this program.</p>
                    }
                    else
                    {
                        @foreach (var rule in _rules)
                        {
                            var treatments = _ruleTreatments
                            .Where(t => t.ProgramTemplateRuleId == rule.ProgramTemplateRuleId)
                            .ToList();

                            <div class="card border mb-3">
                                <div class="card-body py-3">
                                    <div class="row">
                                        <div class="col-sm-4">
                                            <div class="text-muted small text-uppercase fw-semibold mb-1">Animal Type</div>
                                            <div>@(_animalTypeNames.TryGetValue(rule.AnimalTypeCode ?? "", out var name) ? name : rule.AnimalTypeCode ?? "Any")</div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="text-muted small text-uppercase fw-semibold mb-1">Gender</div>
                                            <div>@GetGenderLabel(rule.Gender)</div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="text-muted small text-uppercase fw-semibold mb-1">Age Range</div>
                                            <div>@GetAgeRangeLabel(rule.MinBirthYear, rule.MaxBirthYear)</div>
                                        </div>
                                    </div>
                                    <hr class="my-3" />
                                    <div class="text-muted small text-uppercase fw-semibold mb-2">Treatments</div>
                                    @if (treatments.Any())
                                    {
                                        @foreach (var t in treatments)
                                        {
                                            var treatmentName = _treatmentNames.TryGetValue(t.TreatmentCode, out var tn) ? tn : t.TreatmentCode;
                                            <span class="badge bg-primary me-1 mb-1">
                                                @treatmentName
                                                @if (t.IsMandatory)
                                                {
                                                    <span class="ms-1 opacity-75">· Mandatory</span>
                                                }
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No treatments assigned.</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header py-3">
                    <h6 class="mb-0"><i class="bx bx-info-circle me-1"></i>Details</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="text-muted small text-uppercase fw-semibold mb-1">Description</div>
                        <div>@(string.IsNullOrEmpty(_template.Description) ? "No description." : _template.Description)</div>
                    </div>
                    <div class="mb-3">
                        <div class="text-muted small text-uppercase fw-semibold mb-1">Created</div>
                        <div>@_template.CreatedDate.ToString("dd MMM yyyy")</div>
                    </div>
                    <div>
                        <div class="text-muted small text-uppercase fw-semibold mb-1">Rules</div>
                        <div>@_rules.Count rule(s)</div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header py-3">
                    <h6 class="mb-0"><i class="bx bx-cog me-1"></i>Actions</h6>
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <button class="btn btn-outline-primary btn-sm" disabled title="Coming soon">
                        <i class="bx bx-pencil me-1"></i>Edit Program
                    </button>
                    <button class="btn btn-outline-danger btn-sm" disabled title="Coming soon">
                        <i class="bx bx-trash me-1"></i>Delete Program
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ProgramTemplateCode { get; set; } = "";

    private bool _loading = true;
    private ProgramTemplateDTO? _template;
    private List<ProgramTemplateRuleDTO> _rules = new();
    private List<ProgramTemplateRuleTreatmentDTO> _ruleTreatments = new();
    private Dictionary<string, string> _treatmentNames = new();
    private Dictionary<string, string> _animalTypeNames = new();

    protected override async Task OnInitializedAsync()
    {
        _template = await ProgramTemplateService.GetByIdAsync(ProgramTemplateCode);
        if (_template == null) { _loading = false; return; }

        var allRules = await ProgramTemplateRuleService.GetAllAsync();
        _rules = allRules.Where(r => r.ProgramTemplateCode == ProgramTemplateCode).ToList();

        var allRuleTreatments = await ProgramTemplateRuleTreatmentService.GetAllAsync();
        _ruleTreatments = allRuleTreatments
            .Where(t => _rules.Any(r => r.ProgramTemplateRuleId == t.ProgramTemplateRuleId))
            .ToList();

        var treatments = await TreatmentService.GetAllAsync();
        _treatmentNames = treatments.ToDictionary(t => t.TreatmentCode, t => t.TreatmentName);

        var animalTypes = await AnimalTypeService.GetAllAsync();
        _animalTypeNames = animalTypes.ToDictionary(a => a.AnimalTypeCode, a => a.AnimalTypeName);

        _loading = false;
    }

    private string GetGenderLabel(string? gender) => gender switch
    {
        "M" => "Male",
        "F" => "Female",
        _ => "Any"
    };

    private string GetFrequencyLabel(string? frequency) => frequency switch
    {
        "OnceOff" => "Once-off",
        "Monthly" => "Monthly",
        "Quarterly" => "Quarterly",
        "BiYearly" => "Bi-yearly",
        "Yearly" => "Yearly",
        _ => frequency ?? "Unknown"
    };

    private string GetAgeRangeLabel(int? min, int? max)
    {
        if (min == null && max == null) return "Any age";
        if (min == max) return $"Born {min}";
        if (min == null) return $"Born {max} or earlier";
        if (max == null) return $"Born {min} or later";
        return $"{min} – {max}";
    }
}